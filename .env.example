# --- Database Connection Settings (Java/Maven) ---
# If using Docker, ensure the port matches DOCKER_DB_PORT below.
# If using local MySQL, the default port is usually 3306.
DB_URL=jdbc:mysql://localhost:3306/db_kosku
DB_USER=root
DB_PASSWORD=  # Fill this with your actual MySQL root password or docker DB password;

# --- Docker MySQL Configuration (Optional) ---
# This section is only required if you are running the database via Docker.
DOCKER_DB_PORT=
DOCKER_DB_ROOT_PASSWORD=
DOCKER_DB_NAME=

# IMPORTANT: 
# If you change DOCKER_DB_PORT, you MUST also update the port in DB_URL 
# to ensure the Java application can reach the Docker container.