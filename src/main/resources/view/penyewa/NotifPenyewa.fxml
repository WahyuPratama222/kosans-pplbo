<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1080.0" prefWidth="1920.0"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.kosku.controller.NotifPenyewaController">

    <top>
        <fx:include source="NavbarPenyewa.fxml" />
    </top>

    <center>
        <HBox style="-fx-background-color: #F0F4FF;" prefHeight="1010.0">

            <!-- LEFT: Kategori Notifikasi -->
            <VBox prefWidth="320.0" spacing="8.0"
                style="-fx-background-color: white; -fx-padding: 32 20 32 20; -fx-border-color: transparent #E8EDF5 transparent transparent; -fx-border-width: 0 1 0 0;">
                <Label text="🔔 Filter Notifikasi" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A3A6B; -fx-padding: 0 0 12 0;" />

                <Button text="🔵  Semua Notifikasi" onAction="#filterSemua" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #2D6BE4; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12; -fx-alignment: CENTER_LEFT;" />
                <Button text="🏠  Info Kamar" onAction="#filterKamar" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #F0F4FF; -fx-text-fill: #333; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12; -fx-alignment: CENTER_LEFT;" />
                <Button text="💰  Pembayaran" onAction="#filterBayar" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #F0F4FF; -fx-text-fill: #333; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12; -fx-alignment: CENTER_LEFT;" />
                <Button text="📋  Kontrak" onAction="#filterKontrak" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #F0F4FF; -fx-text-fill: #333; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12; -fx-alignment: CENTER_LEFT;" />
                <Button text="📢  Pengumuman" onAction="#filterPengumuman" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #F0F4FF; -fx-text-fill: #333; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12; -fx-alignment: CENTER_LEFT;" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="🗑️  Hapus Semua Notifikasi" onAction="#hapusSemua" mnemonicParsing="false" prefWidth="280.0"
                    style="-fx-background-color: #FFF0F0; -fx-text-fill: #CC3333; -fx-font-size: 12px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10; -fx-border-color: #FFCCCC; -fx-border-radius: 10;" />
            </VBox>

            <!-- RIGHT: Daftar Notifikasi -->
            <VBox HBox.hgrow="ALWAYS" spacing="0.0" style="-fx-background-color: #F0F4FF;">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="16.0"
                    style="-fx-padding: 32 40 20 40;">
                    <Label text="Notifikasi" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1A3A6B;" />
                    <Label fx:id="lblJumlahBelumDibaca" text="3 belum dibaca"
                        style="-fx-background-color: #2D6BE4; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 3 12 3 12;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✅  Tandai Semua Dibaca" onAction="#tandaiSemua" mnemonicParsing="false"
                        style="-fx-background-color: white; -fx-text-fill: #2D6BE4; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 9 18 9 18; -fx-border-color: #C5D8FF; -fx-border-radius: 10;" />
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: #F0F4FF; -fx-background: #F0F4FF;">
                    <content>
                        <VBox fx:id="vboxNotif" spacing="14.0" style="-fx-padding: 0 40 40 40;">

                            <!-- Label Hari -->
                            <Label text="Hari ini" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888; -fx-padding: 8 0 0 0;" />

                            <!-- Notif 1: BELUM DIBACA - Info Kamar -->
                            <HBox spacing="16.0" alignment="TOP_LEFT"
                                style="-fx-background-color: #EEF3FF; -fx-background-radius: 14; -fx-padding: 20 24 20 24; -fx-border-color: #C5D8FF; -fx-border-radius: 14; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(45,107,228,0.08), 8, 0, 0, 2);">
                                <Label text="🏠" style="-fx-font-size: 28px;" />
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="Kamar Siap Ditempati"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A3A6B;" />
                                        <Label text="● BARU"
                                            style="-fx-font-size: 11px; -fx-text-fill: #2D6BE4; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="10:30"
                                            style="-fx-font-size: 12px; -fx-text-fill: #888;" />
                                    </HBox>
                                    <Label text="Kamar nomor 12 di Kos Deluxe sudah siap untuk Anda tempati. Silakan hubungi admin untuk pengambilan kunci."
                                        wrapText="true"
                                        style="-fx-font-size: 13px; -fx-text-fill: #444; -fx-max-width: 1200;" />
                                    <HBox spacing="10.0" style="-fx-padding: 6 0 0 0;">
                                        <Button text="Hubungi Admin" mnemonicParsing="false"
                                            style="-fx-background-color: #2D6BE4; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16;" />
                                        <Button text="Lihat Detail" mnemonicParsing="false"
                                            style="-fx-background-color: white; -fx-text-fill: #2D6BE4; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16; -fx-border-color: #C5D8FF; -fx-border-radius: 8;" />
                                    </HBox>
                                </VBox>
                                <Button text="✕" mnemonicParsing="false"
                                    style="-fx-background-color: transparent; -fx-text-fill: #BBB; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;" />
                            </HBox>

                            <!-- Notif 2: BELUM DIBACA - Pembayaran -->
                            <HBox spacing="16.0" alignment="TOP_LEFT"
                                style="-fx-background-color: #FFF8EC; -fx-background-radius: 14; -fx-padding: 20 24 20 24; -fx-border-color: #FFD98E; -fx-border-radius: 14; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(255,180,0,0.1), 8, 0, 0, 2);">
                                <Label text="💰" style="-fx-font-size: 28px;" />
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="Tagihan Sewa Bulan Mei"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #92400E;" />
                                        <Label text="● BARU"
                                            style="-fx-font-size: 11px; -fx-text-fill: #D97706; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="08:00"
                                            style="-fx-font-size: 12px; -fx-text-fill: #888;" />
                                    </HBox>
                                    <Label text="Tagihan sewa bulan Mei sebesar Rp 1.200.000 sudah tersedia. Jatuh tempo: 5 Mei 2024. Bayar tepat waktu dan hindari denda."
                                        wrapText="true"
                                        style="-fx-font-size: 13px; -fx-text-fill: #78350F; -fx-max-width: 1200;" />
                                    <HBox spacing="10.0" style="-fx-padding: 6 0 0 0;">
                                        <Button text="Bayar Sekarang" mnemonicParsing="false"
                                            style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16;" />
                                        <Button text="Lihat Tagihan" mnemonicParsing="false"
                                            style="-fx-background-color: white; -fx-text-fill: #D97706; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16; -fx-border-color: #FFD98E; -fx-border-radius: 8;" />
                                    </HBox>
                                </VBox>
                                <Button text="✕" mnemonicParsing="false"
                                    style="-fx-background-color: transparent; -fx-text-fill: #BBB; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;" />
                            </HBox>

                            <!-- Notif 3: BELUM DIBACA - Kontrak -->
                            <HBox spacing="16.0" alignment="TOP_LEFT"
                                style="-fx-background-color: #F0FDF4; -fx-background-radius: 14; -fx-padding: 20 24 20 24; -fx-border-color: #86EFAC; -fx-border-radius: 14; -fx-border-width: 1;">
                                <Label text="📋" style="-fx-font-size: 28px;" />
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="Kontrak Berhasil Diperbarui"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #14532D;" />
                                        <Label text="● BARU"
                                            style="-fx-font-size: 11px; -fx-text-fill: #16A34A; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="07:15"
                                            style="-fx-font-size: 12px; -fx-text-fill: #888;" />
                                    </HBox>
                                    <Label text="Kontrak sewa Anda telah berhasil diperbarui untuk periode 1 Mei 2024 – 30 April 2025. Silakan unduh salinan kontrak Anda."
                                        wrapText="true"
                                        style="-fx-font-size: 13px; -fx-text-fill: #166534; -fx-max-width: 1200;" />
                                    <HBox spacing="10.0" style="-fx-padding: 6 0 0 0;">
                                        <Button text="Unduh Kontrak" mnemonicParsing="false"
                                            style="-fx-background-color: #16A34A; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16;" />
                                    </HBox>
                                </VBox>
                                <Button text="✕" mnemonicParsing="false"
                                    style="-fx-background-color: transparent; -fx-text-fill: #BBB; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;" />
                            </HBox>

                            <!-- Label Kemarin -->
                            <Label text="Kemarin" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888; -fx-padding: 8 0 0 0;" />

                            <!-- Notif 4: SUDAH DIBACA -->
                            <HBox spacing="16.0" alignment="TOP_LEFT"
                                style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 24 20 24; -fx-border-color: #E8EDF5; -fx-border-radius: 14; -fx-border-width: 1;">
                                <Label text="📢" style="-fx-font-size: 28px; -fx-opacity: 0.65;" />
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="Pengumuman: Jadwal Kebersihan"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="Kemarin, 09:00"
                                            style="-fx-font-size: 12px; -fx-text-fill: #BBB;" />
                                    </HBox>
                                    <Label text="Pengingat: Jadwal kebersihan bersama dilaksanakan setiap Minggu pukul 07.00 – 09.00 WIB. Mohon partisipasinya."
                                        wrapText="true"
                                        style="-fx-font-size: 13px; -fx-text-fill: #999; -fx-max-width: 1200;" />
                                </VBox>
                                <Button text="✕" mnemonicParsing="false"
                                    style="-fx-background-color: transparent; -fx-text-fill: #DDD; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;" />
                            </HBox>

                            <!-- Notif 5: SUDAH DIBACA -->
                            <HBox spacing="16.0" alignment="TOP_LEFT"
                                style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 24 20 24; -fx-border-color: #E8EDF5; -fx-border-radius: 14; -fx-border-width: 1;">
                                <Label text="💬" style="-fx-font-size: 28px; -fx-opacity: 0.65;" />
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="Pesan Baru dari Admin"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="Kemarin, 14:22"
                                            style="-fx-font-size: 12px; -fx-text-fill: #BBB;" />
                                    </HBox>
                                    <Label text="Pak Budi mengirim pesan: 'Halo, ada yang bisa saya bantu?'"
                                        wrapText="true"
                                        style="-fx-font-size: 13px; -fx-text-fill: #999; -fx-max-width: 1200;" />
                                    <HBox spacing="10.0" style="-fx-padding: 6 0 0 0;">
                                        <Button text="Buka Chat" mnemonicParsing="false"
                                            style="-fx-background-color: #F0F4FF; -fx-text-fill: #2D6BE4; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 16 7 16; -fx-border-color: #C5D8FF; -fx-border-radius: 8;" />
                                    </HBox>
                                </VBox>
                                <Button text="✕" mnemonicParsing="false"
                                    style="-fx-background-color: transparent; -fx-text-fill: #DDD; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;" />
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
