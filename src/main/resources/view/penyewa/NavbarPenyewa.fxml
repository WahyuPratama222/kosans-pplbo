<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="70.0" prefWidth="1920.0" style="-fx-background-color: linear-gradient(to right, #1A3A6B, #2D6BE4);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kosku.controller.NavbarController">
    <center>
        <AnchorPane prefHeight="70.0" prefWidth="1920.0" BorderPane.alignment="CENTER">
            <children>

                <!-- Logo & Brand -->
                <HBox alignment="CENTER_LEFT" spacing="12.0" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="40.0" AnchorPane.topAnchor="12.0">
                    <children>
                        <Label onMouseClicked="#goToMainMenu" style="-fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 20px; -fx-font-style: italic;" text="KosKurniawan" />
                    </children>
                </HBox>

                <!-- Navigation Menu -->
                <HBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#goToMainMenu" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20 8 20; -fx-background-radius: 20;" text="🏠  Beranda" />
                        <Button mnemonicParsing="false" onAction="#goToRiwayat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20 8 20; -fx-background-radius: 20;" text="📋  Riwayat" />
                        <Button mnemonicParsing="false" onAction="#goToChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20 8 20; -fx-background-radius: 20;" text="💬  Chat" />
                        <Button mnemonicParsing="false" onAction="#goToNotif" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20 8 20; -fx-background-radius: 20;" text="🔔  Notifikasi" />
                    </children>
                </HBox>

                <!-- Profile + Logout -->
                <HBox alignment="CENTER_RIGHT" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label fx:id="lblNamaPengguna" style="-fx-text-fill: #D0E4FF; -fx-font-size: 15px;" text="Halo, User!" />
                        <ImageView fitHeight="50.0" fitWidth="50.0" onMouseClicked="#handleLogout" pickOnBounds="true" preserveRatio="false" style="-fx-cursor: hand;">
                            <image>
                                <Image url="@../../images/tesProfile.png" />
                            </image>
                            <clip>
                                <Circle centerX="25" centerY="25" radius="25" />
                            </clip>
                        </ImageView>
                        <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 16 6 16; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.5); -fx-border-radius: 20;" text="Log Out" />
                    </children>
                </HBox>

            </children>
        </AnchorPane>
    </center>
</BorderPane>
