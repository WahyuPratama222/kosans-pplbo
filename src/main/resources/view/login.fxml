<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="main-container" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.kosku.controller.LoginController">
   
   <center>
      <VBox alignment="CENTER" spacing="15.0" maxWidth="400.0" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="label-title" text="SELAMAT DATANG">
               <font>
                  <Font name="System Bold Italic" size="18.0" />
               </font>
            </Label>
            
            <Label styleClass="label-subtitle" text="Login ke Akun Anda" />

            <VBox spacing="10.0">
               <children>
                  <TextField fx:id="emailField" prefHeight="40.0" promptText="Email" styleClass="text-field" />
                  <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Password" styleClass="text-field" />
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT">
               <children>
                  <CheckBox mnemonicParsing="false" text="Remember me" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="text-bold" text="Forget password?" style="-fx-cursor: hand;" />
               </children>
            </HBox>

            <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" 
                    prefHeight="40.0" prefWidth="400.0" styleClass="btn-primary" text="Login" />

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label styleClass="label-muted" text="Don't Have an account?" />
                  <Label onMouseClicked="#handleGoToRegister" styleClass="text-info, text-bold" 
                         text="Regist Here" style="-fx-cursor: hand;" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>