<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css">
    <!-- TOP NAVBAR -->
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #31487A, #8FB3E2);" styleClass="navbar-admin">
            <left>
                <Label text="📋 Laporan Booking" style="-fx-text-fill: white;" styleClass="navbar-title" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button text="← Kembali" styleClass="btn-outline" style="-fx-text-fill: white; -fx-padding: 5 15; -fx-border-color: white;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Button>
            </right>
        </BorderPane>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #F8FAFC;">
            <VBox spacing="20" styleClass="page-content">
                <!-- HEADER -->
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Laporan Booking Sistem" styleClass="label-title" />
                            <Label text="Lihat semua booking dari penyewa ke kos di sistem" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        </VBox>
                        <Button text="📥 Unduh Excel" styleClass="btn-secondary" prefWidth="150" />
                        <Button text="📄 Export PDF" styleClass="btn-secondary" prefWidth="130" />
                    </HBox>
                    <Separator />
                </VBox>

                <!-- FILTER -->
                <HBox spacing="10">
                    <DatePicker promptText="Dari Tanggal" styleClass="text-field" prefWidth="140" />
                    <DatePicker promptText="Sampai Tanggal" styleClass="text-field" prefWidth="140" />
                    <ComboBox promptText="Status Booking" prefWidth="150" styleClass="combo-box">
                        <items>
                            <String fx:value="Semua" />
                            <String fx:value="Pending" />
                            <String fx:value="Confirmed" />
                            <String fx:value="Active" />
                            <String fx:value="Completed" />
                            <String fx:value="Cancelled" />
                        </items>
                    </ComboBox>
                    <TextField promptText="Cari nama penyewa atau ID booking..." prefWidth="250" styleClass="text-field" />
                    <Button text="🔍 Filter" styleClass="btn-secondary" prefWidth="100" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻ Reset" styleClass="btn-outline" prefWidth="80" />
                </HBox>

                <!-- STATISTICS SECTION -->
                <HBox spacing="15">
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Booking" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="1,205" style="-fx-text-fill: #1E2E4F; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Booking Aktif" style="-fx-text-fill: #10B981; -fx-font-size: 12px;" />
                        <Label text="847 (70%)" style="-fx-text-fill: #10B981; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Booking Pending" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;" />
                        <Label text="28 (2%)" style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Booking Selesai" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="312 (26%)" style="-fx-text-fill: #64748B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Booking Dibatalkan" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;" />
                        <Label text="18 (2%)" style="-fx-text-fill: #EF4444; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- STATUS DISTRIBUTION -->
                <HBox spacing="15">
                    <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Distribusi Status Booking" styleClass="card-header" />
                        <VBox spacing="8" style="-fx-padding: 10;">
                            <HBox spacing="10">
                                <Label text="✅ Confirmed" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.70" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="847" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="⏳ Pending" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.02" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="28" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="✔️ Completed" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.26" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="312" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="❌ Cancelled" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.02" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="18" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- BOOKING DURATION -->
                    <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Durasi Booking" styleClass="card-header" />
                        <VBox spacing="8" style="-fx-padding: 10;">
                            <HBox spacing="10">
                                <Label text="1 Bulan" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.15" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="180" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="3 Bulan" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.35" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="422" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="6 Bulan" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.35" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="421" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="12 Bulan" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                                <ProgressBar progress="0.15" prefWidth="150" HBox.hgrow="ALWAYS" />
                                <Label text="182" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- BOOKING TABLE -->
                <VBox styleClass="card" spacing="10">
                    <Label text="Detail Booking" styleClass="card-header" />
                    <TableView style="-fx-font-size: 10px;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID Booking" prefWidth="90" />
                            <TableColumn text="Nama Penyewa" prefWidth="130" />
                            <TableColumn text="Kos • Kamar" prefWidth="150" />
                            <TableColumn text="Check-in" prefWidth="100" />
                            <TableColumn text="Check-out" prefWidth="100" />
                            <TableColumn text="Durasi" prefWidth="70" />
                            <TableColumn text="Total" prefWidth="110" />
                            <TableColumn text="Status" prefWidth="90" />
                            <TableColumn text="Tanggal Booking" prefWidth="110" />
                            <TableColumn text="Aksi" prefWidth="90" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- PAGINATION -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Button text="← Sebelumnya" styleClass="btn-outline" prefWidth="100" />
                    <Label text="Halaman 1 dari 30" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                    <Button text="Selanjutnya →" styleClass="btn-outline" prefWidth="100" />
                    <Separator orientation="VERTICAL" />
                    <Label text="Tampilkan per halaman:" style="-fx-text-fill: #64748B;" />
                    <ComboBox styleClass="combo-box" prefWidth="80">
                        <items>
                            <String fx:value="10" />
                            <String fx:value="25" />
                            <String fx:value="50" />
                            <String fx:value="100" />
                        </items>
                    </ComboBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
