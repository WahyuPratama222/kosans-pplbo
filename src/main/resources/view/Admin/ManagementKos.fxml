<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css">
    <!-- TOP NAVBAR -->
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #31487A, #8FB3E2);" styleClass="navbar-admin">
            <left>
                <Label text="🏠 Manajemen Kos" style="-fx-text-fill: white;" styleClass="navbar-title" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button text="← Kembali" styleClass="btn-outline" style="-fx-text-fill: white; -fx-padding: 5 15; -fx-border-color: white;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Button>
            </right>
        </BorderPane>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #F8FAFC;">
            <VBox spacing="20" styleClass="page-content">
                <!-- HEADER -->
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Pantau dan Kelola Semua Kos" styleClass="label-title" />
                            <Label text="Lihat status, kamar, dan pendapatan dari setiap kos" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        </VBox>
                        <Button text="➕ Tambah Kos" styleClass="btn-primary" prefWidth="140" />
                    </HBox>
                    <Separator />
                </VBox>

                <!-- SEARCH & FILTER -->
                <HBox spacing="10">
                    <TextField promptText="Cari berdasarkan nama, lokasi, atau pemilik..." prefWidth="300" styleClass="text-field" />
                    <ComboBox promptText="Urutkan Berdasarkan" prefWidth="150" styleClass="combo-box">
                        <items>
                            <String fx:value="Nama" />
                            <String fx:value="Lokasi" />
                            <String fx:value="Pendapatan" />
                            <String fx:value="Rating" />
                        </items>
                    </ComboBox>
                    <Button text="🔍 Cari" styleClass="btn-secondary" prefWidth="100" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻ Reset" styleClass="btn-outline" prefWidth="80" />
                </HBox>

                <!-- STATISTICS CARDS -->
                <HBox spacing="15">
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Kos" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="328" style="-fx-text-fill: #1E2E4F; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Kamar" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="4,247" style="-fx-text-fill: #31487A; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Kamar Terisi" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="3,542 (83%)" style="-fx-text-fill: #10B981; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Pendapatan Bulan Ini" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="Rp 2.5B" style="-fx-text-fill: #31487A; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- KOS GRID -->
                <VBox spacing="15">
                    <Label text="Daftar Kos" styleClass="label-subtitle" />
                    
                    <VBox spacing="10">
                        <!-- Kos Card 1 -->
                        <HBox styleClass="card" spacing="15" style="-fx-padding: 15;">
                            <Label text="🏢" style="-fx-font-size: 32px;" VBox.vgrow="ALWAYS" />
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label text="Kos Kurniawan - Utama" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                        <Label text="Jl. Ahmad Yani No. 45, Bandung" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" />
                                        <Label text="Pemilik: Kurniawan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                    </VBox>
                                    <VBox spacing="3" style="-fx-alignment: top-right;">
                                        <HBox spacing="15">
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Kamar" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="20/20" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Rating" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="4.8/5" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Pendapatan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="Rp 12.5M" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>
                            <VBox spacing="5" style="-fx-alignment: center;">
                                <Button text="👁️ Lihat" styleClass="btn-secondary" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="✏️ Edit" styleClass="btn-secondary" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="❌ Hapus" styleClass="btn-danger" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                            </VBox>
                        </HBox>

                        <!-- Kos Card 2 -->
                        <HBox styleClass="card" spacing="15" style="-fx-padding: 15;">
                            <Label text="🏘️" style="-fx-font-size: 32px;" VBox.vgrow="ALWAYS" />
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label text="Kos Kurniawan - Cabang 1" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                        <Label text="Jl. Gatot Subroto No. 89, Bandung" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" />
                                        <Label text="Pemilik: Kurniawan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                    </VBox>
                                    <VBox spacing="3" style="-fx-alignment: top-right;">
                                        <HBox spacing="15">
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Kamar" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="15/15" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Rating" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="4.6/5" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                            <VBox spacing="2" style="-fx-alignment: center; -fx-padding: 8 12; -fx-background-color: #D9E1F1; -fx-border-radius: 4;">
                                                <Label text="Pendapatan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                                <Label text="Rp 9.2M" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>
                            <VBox spacing="5" style="-fx-alignment: center;">
                                <Button text="👁️ Lihat" styleClass="btn-secondary" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="✏️ Edit" styleClass="btn-secondary" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="❌ Hapus" styleClass="btn-danger" prefWidth="90" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- PAGINATION -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Button text="← Sebelumnya" styleClass="btn-outline" prefWidth="100" />
                    <Label text="Halaman 1 dari 8" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                    <Button text="Selanjutnya →" styleClass="btn-outline" prefWidth="100" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
