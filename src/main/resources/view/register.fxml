<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="main-container" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.kosku.controller.RegisterController">
   
   <center>
      <VBox alignment="CENTER" spacing="15.0" maxWidth="450.0" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="label-title" text="REGISTRASI">
               <font>
                  <Font name="System Bold Italic" size="18.0" />
               </font>
            </Label>
            
            <Label styleClass="label-subtitle" text="Buat Akun Baru Anda" />

            <VBox spacing="10.0">
               <children>
                  <TextField fx:id="usernameField" prefHeight="40.0" promptText="Username" styleClass="text-field" />
                  <TextField fx:id="emailField" prefHeight="40.0" promptText="Email" styleClass="text-field" />
                  <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Password" styleClass="text-field" />
                  <ComboBox fx:id="roleComboBox" prefHeight="40.0" prefWidth="450.0" promptText="Pilih Role" styleClass="combo-box" />
               </children>
            </VBox>

            <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" 
                    prefHeight="40.0" prefWidth="450.0" styleClass="btn-primary" text="Register" />

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label styleClass="label-muted" text="Already have an account?" />
                  <Label onMouseClicked="#handleGoToLogin" styleClass="text-info, text-bold" 
                         text="Login Here" style="-fx-cursor: hand;" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
