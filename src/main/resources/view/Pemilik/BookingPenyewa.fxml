<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css">
    <!-- TOP NAVBAR -->
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);" className="navbar-pemilik">
            <left>
                <Label text="📋 Booking Penyewa" style="-fx-text-fill: white;" className="navbar-title" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button text="← Kembali" className="btn-outline" style="-fx-text-fill: white; -fx-padding: 5 15; -fx-border-color: white;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Button>
            </right>
        </BorderPane>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #F8FAFC;">
            <VBox spacing="20" className="page-content">
                <!-- HEADER -->
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Booking Penyewa Anda" className="label-title" />
                            <Label text="Lihat dan kelola semua booking dari penyewa untuk kos Anda" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        </VBox>
                        <Button text="📥 Export" className="btn-secondary" prefWidth="120" />
                    </HBox>
                    <Separator />
                </VBox>

                <!-- FILTER & SEARCH -->
                <HBox spacing="10">
                    <ComboBox promptText="Semua Status" prefWidth="150" className="combo-box">
                        <items>
                            <String fx:value="Semua" />
                            <String fx:value="Pending" />
                            <String fx:value="Confirmed" />
                            <String fx:value="Active" />
                            <String fx:value="Completed" />
                            <String fx:value="Cancelled" />
                        </items>
                    </ComboBox>
                    <ComboBox promptText="Pilih Kos" prefWidth="200" className="combo-box">
                        <items>
                            <String fx:value="Semua Kos" />
                            <String fx:value="Kos Kurniawan - Utama" />
                            <String fx:value="Kos Kurniawan - Cabang 1" />
                            <String fx:value="Kos Kurniawan - Cabang 2" />
                        </items>
                    </ComboBox>
                    <TextField promptText="Cari nama penyewa atau ID booking..." prefWidth="250" className="text-field" />
                    <Button text="🔍 Cari" className="btn-secondary" prefWidth="100" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻ Reset" className="btn-outline" prefWidth="80" />
                </HBox>

                <!-- STATISTICS -->
                <HBox spacing="15">
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Booking" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="147" style="-fx-text-fill: #1E2E4F; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Pending Konfirmasi" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;" />
                        <Label text="5" style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Booking Aktif" style="-fx-text-fill: #10B981; -fx-font-size: 12px;" />
                        <Label text="128" style="-fx-text-fill: #10B981; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Selesai/Dibatalkan" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="14" style="-fx-text-fill: #64748B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- PENDING BOOKINGS ALERT -->
                <HBox className="alert-box alert-warning" spacing="10">
                    <Label text="⚠️" style="-fx-font-size: 16px;" />
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Ada 5 booking yang menunggu konfirmasi Anda" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                        <Label text="Silakan review dan konfirmasi booking segera untuk memberikan kepastian kepada penyewa" style="-fx-font-size: 10px;" />
                    </VBox>
                    <Button text="Lihat" className="btn-warning" style="-fx-padding: 5 15;" />
                </HBox>

                <!-- BOOKING TABLE -->
                <VBox className="card" spacing="10">
                    <Label text="Daftar Booking Terbaru" className="card-header" />
                    <TableView style="-fx-font-size: 11px;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID Booking" prefWidth="100" />
                            <TableColumn text="Nama Penyewa" prefWidth="140" />
                            <TableColumn text="Kamar" prefWidth="80" />
                            <TableColumn text="Check-in" prefWidth="100" />
                            <TableColumn text="Check-out" prefWidth="100" />
                            <TableColumn text="Total Harga" prefWidth="110" />
                            <TableColumn text="Status" prefWidth="100" />
                            <TableColumn text="Tanggal Booking" prefWidth="110" />
                            <TableColumn text="Aksi" prefWidth="180" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- BOOKING DETAILS CARDS -->
                <Label text="Detail Booking" className="label-subtitle" />
                <VBox spacing="10">
                    <!-- Booking Card 1 - Pending -->
                    <VBox className="card" spacing="10">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="⏳" style="-fx-font-size: 32px;" />
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="ID: #KOS-2026-001" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                                    <Label text="PENDING" style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-padding: 2 8; -fx-border-radius: 3; -fx-font-size: 9px; -fx-font-weight: bold;" />
                                </HBox>
                                <Label text="Penyewa: Andi Wijaya | Kamar 12 (Double Bed) | Kos Utama" style="-fx-font-size: 11px;" />
                                <Label text="Check-in: 25 Apr 2026 | Check-out: 25 Jul 2026 | Durasi: 3 bulan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Harga Total: Rp 3.600.000 | Status Pembayaran: Belum Dibayar" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                            </VBox>
                            <VBox spacing="5">
                                <Button text="✅ Konfirmasi" className="btn-success" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="❌ Tolak" className="btn-danger" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="👁️ Lihat Detail" className="btn-secondary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Booking Card 2 - Confirmed -->
                    <VBox className="card" spacing="10">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="✅" style="-fx-font-size: 32px;" />
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="ID: #KOS-2026-089" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                                    <Label text="ACTIVE" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-padding: 2 8; -fx-border-radius: 3; -fx-font-size: 9px; -fx-font-weight: bold;" />
                                </HBox>
                                <Label text="Penyewa: Budi Santoso | Kamar 8 (Single Bed) | Kos Utama" style="-fx-font-size: 11px;" />
                                <Label text="Check-in: 01 Apr 2026 | Check-out: 01 May 2026 | Durasi: 1 bulan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Harga Total: Rp 850.000 | Status Pembayaran: Lunas" style="-fx-font-size: 10px; -fx-text-fill: #10B981;" />
                            </VBox>
                            <VBox spacing="5">
                                <Button text="📝 Edit" className="btn-secondary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="🔄 Perpanjang" className="btn-primary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="👁️ Lihat Detail" className="btn-secondary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Booking Card 3 - Active -->
                    <VBox className="card" spacing="10">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="🔄" style="-fx-font-size: 32px;" />
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="ID: #KOS-2026-122" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                                    <Label text="ACTIVE" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-padding: 2 8; -fx-border-radius: 3; -fx-font-size: 9px; -fx-font-weight: bold;" />
                                </HBox>
                                <Label text="Penyewa: Siti Nurhaliza | Kamar 10 (Double Bed) | Kos Utama" style="-fx-font-size: 11px;" />
                                <Label text="Check-in: 15 Feb 2026 | Check-out: 15 Aug 2026 | Durasi: 6 bulan" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Harga Total: Rp 7.200.000 | Status Pembayaran: Lunas (Cicilan 3/6)" style="-fx-font-size: 10px; -fx-text-fill: #10B981;" />
                            </VBox>
                            <VBox spacing="5">
                                <Button text="📝 Edit" className="btn-secondary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="⏹️ Hentikan" className="btn-danger" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                                <Button text="👁️ Lihat Detail" className="btn-secondary" prefWidth="110" style="-fx-padding: 5 10; -fx-font-size: 10px;" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- PAGINATION -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Button text="← Sebelumnya" className="btn-outline" prefWidth="100" />
                    <Label text="Halaman 1 dari 4" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                    <Button text="Selanjutnya →" className="btn-outline" prefWidth="100" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
