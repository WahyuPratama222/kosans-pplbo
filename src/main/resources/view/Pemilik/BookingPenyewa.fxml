<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kosku.controller.pemilik.BookingPenyewaController">
    <top>
        <fx:include fx:id="navbar" source="navbarPemilik.fxml" />
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="main-container">
            <content>
                <VBox spacing="25.0" styleClass="page-content">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="label-title" text="Booking Penyewa Anda" />
                                <Label styleClass="text-muted" text="Lihat dan kelola semua booking dari penyewa untuk kos Anda" />
                            </children>
                        </VBox>

                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card" style="-fx-padding: 15;">
                            <children>
                                <ComboBox prefWidth="180.0" promptText="Semua Status" styleClass="combo-box">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua" />
                                            <String fx:value="Pending" />
                                            <String fx:value="Confirmed" />
                                            <String fx:value="Active" />
                                            <String fx:value="Completed" />
                                            <String fx:value="Cancelled" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <ComboBox prefWidth="220.0" promptText="Pilih Properti Kos" styleClass="combo-box">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua Kos" />
                                            <String fx:value="Kos Kurniawan - Utama" />
                                            <String fx:value="Kos Kurniawan - Cabang 1" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <TextField prefWidth="300.0" promptText="Cari nama penyewa..." styleClass="text-field" />
                                <Button prefWidth="100.0" styleClass="btn-secondary" text="🔍 Cari" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button prefWidth="90.0" styleClass="btn-outline" text="↻ Reset" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="📋 Total Booking" />
                                        <Label styleClass="stat-value" text="147" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="⏳ Menunggu Konfirmasi" />
                                        <Label styleClass="stat-value" text="5" textFill="#f59e0b" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="✅ Booking Aktif" />
                                        <Label styleClass="stat-value" text="128" textFill="#10b981" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="alert-warning">
                            <children>
                                <Label style="-fx-font-size: 18px;" text="⚠️" />
                                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Ada 5 booking yang menunggu konfirmasi Anda" />
                                        <Label style="-fx-font-size: 11px;" text="Silakan review dan konfirmasi booking sesegera mungkin." />
                                    </children>
                                </VBox>
                                <Button styleClass="btn-warning" text="Lihat Sekarang" />
                            </children>
                        </HBox>

                        <VBox spacing="15.0" styleClass="card">
                            <children>
                                <Label styleClass="label-subtitle" text="Riwayat Booking Terbaru" />
                                <TableView prefHeight="350.0" styleClass="table-view">
                                    <columns>
                                        <TableColumn prefWidth="120.0" text="ID Booking" />
                                        <TableColumn prefWidth="200.0" text="Penyewa" />
                                        <TableColumn prefWidth="180.0" text="Properti" />
                                        <TableColumn prefWidth="120.0" text="Check-in" />
                                        <TableColumn prefWidth="120.0" text="Status" />
                                        <TableColumn prefWidth="150.0" text="Aksi" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>