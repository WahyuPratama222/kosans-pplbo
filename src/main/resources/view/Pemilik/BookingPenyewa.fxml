<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);">
            <left>
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="📋 Booking Penyewa" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button style="-fx-text-fill: white; -fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 5;" text="← Kembali" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                    </padding>
                    <BorderPane.margin>
                        <Insets right="20.0" />
                    </BorderPane.margin>
                </Button>
            </right>
        </BorderPane>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 25;">
                    <children>
                        <VBox spacing="10.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Booking Penyewa Anda" />
                                                <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px;" text="Lihat dan kelola semua booking dari penyewa untuk kos Anda" />
                                            </children>
                                        </VBox>
                                        <Button prefWidth="120.0" text="📥 Export" />
                                    </children>
                                </HBox>
                                <Separator />
                            </children>
                        </VBox>

                        <HBox spacing="10.0">
                            <children>
                                <ComboBox prefWidth="150.0" promptText="Semua Status">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua" />
                                            <String fx:value="Pending" />
                                            <String fx:value="Confirmed" />
                                            <String fx:value="Active" />
                                            <String fx:value="Completed" />
                                            <String fx:value="Cancelled" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <ComboBox prefWidth="200.0" promptText="Pilih Kos">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua Kos" />
                                            <String fx:value="Kos Kurniawan - Utama" />
                                            <String fx:value="Kos Kurniawan - Cabang 1" />
                                            <String fx:value="Kos Kurniawan - Cabang 2" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <TextField prefWidth="250.0" promptText="Cari nama penyewa..." />
                                <Button prefWidth="100.0" text="🔍 Cari" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button prefWidth="80.0" text="↻ Reset" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Total Booking" textFill="#64748b" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="147" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Pending" textFill="#f59e0b" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="5" textFill="#f59e0b" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Booking Aktif" textFill="#10b981" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="128" textFill="#10b981" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="10.0" style="-fx-background-color: #FFFBEB; -fx-padding: 15; -fx-border-color: #F59E0B; -fx-border-radius: 5;">
                            <children>
                                <Label style="-fx-font-size: 16px;" text="⚠️" />
                                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Ada 5 booking yang menunggu konfirmasi Anda" />
                                        <Label style="-fx-font-size: 11px;" text="Silakan review dan konfirmasi booking segera." />
                                    </children>
                                </VBox>
                                <Button style="-fx-background-color: #F59E0B; -fx-text-fill: white;" text="Lihat" />
                            </children>
                        </HBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Daftar Booking Terbaru" />
                                <TableView prefHeight="300.0">
                                    <columns>
                                        <TableColumn prefWidth="100.0" text="ID Booking" />
                                        <TableColumn prefWidth="150.0" text="Nama Penyewa" />
                                        <TableColumn prefWidth="100.0" text="Check-in" />
                                        <TableColumn prefWidth="100.0" text="Status" />
                                        <TableColumn prefWidth="150.0" text="Aksi" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Detail Booking" />
                        
                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label style="-fx-font-size: 24px;" text="⏳" />
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold;" text="ID: #KOS-2026-001" />
                                                        <Label style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-padding: 2 8; -fx-font-size: 9px;" text="PENDING" />
                                                    </children>
                                                </HBox>
                                                <Label style="-fx-font-size: 11px;" text="Andi Wijaya | Kamar 12 | Kos Utama" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #64748B;" text="Check-in: 25 Apr 2026 | Durasi: 3 bulan" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Button prefWidth="110.0" style="-fx-background-color: #10B981; -fx-text-fill: white;" text="✅ Konfirmasi" />
                                                <Button prefWidth="110.0" style="-fx-background-color: #EF4444; -fx-text-fill: white;" text="❌ Tolak" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>