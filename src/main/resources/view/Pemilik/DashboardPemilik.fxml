<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);">
            <left>
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="🏠 Pemilik Kos Dashboard" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="20.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="👤 Pemilik Kos" />
                        <Button style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-padding: 5 15;" text="Logout" />
                    </children>
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </HBox>
            </right>
        </BorderPane>
    </top>

    <left>
        <VBox prefHeight="700.0" prefWidth="250.0" spacing="10.0" style="-fx-background-color: #1E2E4F;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="MENU" />
                <Separator opacity="0.3" />
                
                <Button maxWidth="Infinity" style="-fx-alignment: center-left; -fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 15;" text="📊 Dashboard" />
                <Button maxWidth="Infinity" style="-fx-alignment: center-left; -fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 15;" text="🏠 Manajemen Kos" />
                <Button maxWidth="Infinity" style="-fx-alignment: center-left; -fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 15;" text="🛏️ Manajemen Kamar" />
                <Button maxWidth="Infinity" style="-fx-alignment: center-left; -fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 15;" text="📋 Booking Penyewa" />
                <Button maxWidth="Infinity" style="-fx-alignment: center-left; -fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 15;" text="💰 Laporan Pembayaran" />
                
                <Region VBox.vgrow="ALWAYS" />
                <Separator opacity="0.3" />
                <Label style="-fx-text-fill: #8FB3E2; -fx-font-size: 10px;" text="v1.0 © 2026" />
            </children>
            <padding>
                <Insets all="15.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 25;">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Selamat Datang, Pemilik Kos" />
                                <Label style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Kelola kos dan kamar Anda dengan mudah" />
                            </children>
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="🏠 Total Kos" textFill="#64748b" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="3" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="🛏️ Total Kamar" textFill="#64748b" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="45" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="💰 Pendapatan" textFill="#64748b" />
                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Rp 28.5M" textFill="#10b981" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Aksi Cepat" />
                        <HBox spacing="10.0">
                            <children>
                                <Button prefWidth="160.0" style="-fx-background-color: #31487A; -fx-text-fill: white;" text="➕ Tambah Kos" />
                                <Button prefWidth="160.0" style="-fx-background-color: #31487A; -fx-text-fill: white;" text="➕ Tambah Kamar" />
                                <Button prefWidth="160.0" style="-fx-background-color: #F59E0B; -fx-text-fill: white;" text="👁️ Lihat Booking" />
                            </children>
                        </HBox>

                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Daftar Kos Anda" />
                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                                    <children>
                                        <Label style="-fx-font-size: 28px;" text="🏢" />
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Kos Kurniawan - Utama" />
                                                <Label style="-fx-font-size: 11px;" text="Jl. Ahmad Yani No. 45, Bandung" textFill="#64748b" />
                                            </children>
                                        </VBox>
                                        <Button style="-fx-font-size: 10px;" text="Lihat Detail" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>