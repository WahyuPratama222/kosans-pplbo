<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css">
    <!-- TOP NAVBAR -->
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);" className="navbar-pemilik">
            <left>
                <Label text="🛏️ Manajemen Kamar" style="-fx-text-fill: white;" className="navbar-title" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button text="← Kembali" className="btn-outline" style="-fx-text-fill: white; -fx-padding: 5 15; -fx-border-color: white;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Button>
            </right>
        </BorderPane>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #F8FAFC;">
            <VBox spacing="20" className="page-content">
                <!-- HEADER -->
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Kelola Kamar di Kos Anda" className="label-title" />
                            <Label text="Tambah, edit, atau hapus kamar dan atur harga sewa" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        </VBox>
                        <Button text="➕ Tambah Kamar" className="btn-primary" prefWidth="150" />
                    </HBox>
                    <Separator />
                </VBox>

                <!-- FILTER & SEARCH -->
                <HBox spacing="10">
                    <ComboBox promptText="Pilih Kos" prefWidth="200" className="combo-box">
                        <items>
                            <String fx:value="Kos Kurniawan - Utama" />
                            <String fx:value="Kos Kurniawan - Cabang 1" />
                            <String fx:value="Kos Kurniawan - Cabang 2" />
                        </items>
                    </ComboBox>
                    <ComboBox promptText="Status" prefWidth="150" className="combo-box">
                        <items>
                            <String fx:value="Semua" />
                            <String fx:value="Tersedia" />
                            <String fx:value="Terisi" />
                            <String fx:value="Maintenance" />
                        </items>
                    </ComboBox>
                    <TextField promptText="Cari nomor kamar..." prefWidth="200" className="text-field" />
                    <Button text="🔍 Cari" className="btn-secondary" prefWidth="100" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻ Reset" className="btn-outline" prefWidth="80" />
                </HBox>

                <!-- STATISTICS -->
                <HBox spacing="15">
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Kamar" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="45" style="-fx-text-fill: #1E2E4F; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Kamar Terisi" style="-fx-text-fill: #10B981; -fx-font-size: 12px;" />
                        <Label text="28 (62%)" style="-fx-text-fill: #10B981; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Kamar Kosong" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="17 (38%)" style="-fx-text-fill: #31487A; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Maintenance" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;" />
                        <Label text="0" style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- KAMAR GRID -->
                <Label text="Daftar Kamar" className="label-subtitle" />
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                    </columnConstraints>

                    <!-- Room Card 1 -->
                    <VBox className="card" spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_RIGHT">
                            <Label text="Tersedia" style="-fx-background-color: #D9E1F1; -fx-text-fill: #31487A; -fx-font-size: 10px; -fx-padding: 3 8; -fx-border-radius: 3;" />
                        </HBox>
                        <VBox spacing="5">
                            <Label text="🛏️ Kamar 101" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                            <Label text="Tipe: Single Bed" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                            <Label text="Lantai 1 • Area A" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <Separator />
                        <VBox spacing="2">
                            <HBox spacing="5">
                                <Label text="Harga:" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Rp 850.000" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <Label text="Penghuni: -" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <HBox spacing="5" style="-fx-padding: 5 0;">
                            <Button text="Edit" className="btn-secondary" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                            <Button text="Hapus" className="btn-danger" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                        </HBox>
                    </VBox>

                    <!-- Room Card 2 -->
                    <VBox className="card" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_RIGHT">
                            <Label text="Terisi" style="-fx-background-color: #D9E1F1; -fx-text-fill: #10B981; -fx-font-size: 10px; -fx-padding: 3 8; -fx-border-radius: 3;" />
                        </HBox>
                        <VBox spacing="5">
                            <Label text="🛏️ Kamar 102" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                            <Label text="Tipe: Single Bed" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                            <Label text="Lantai 1 • Area A" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <Separator />
                        <VBox spacing="2">
                            <HBox spacing="5">
                                <Label text="Harga:" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Rp 850.000" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <Label text="Penghuni: Ahmad Wijaya" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <HBox spacing="5" style="-fx-padding: 5 0;">
                            <Button text="Edit" className="btn-secondary" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                            <Button text="Hapus" className="btn-danger" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                        </HBox>
                    </VBox>

                    <!-- Room Card 3 -->
                    <VBox className="card" spacing="10" GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_RIGHT">
                            <Label text="Terisi" style="-fx-background-color: #D9E1F1; -fx-text-fill: #10B981; -fx-font-size: 10px; -fx-padding: 3 8; -fx-border-radius: 3;" />
                        </HBox>
                        <VBox spacing="5">
                            <Label text="🛏️ Kamar 103" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                            <Label text="Tipe: Double Bed" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                            <Label text="Lantai 1 • Area B" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <Separator />
                        <VBox spacing="2">
                            <HBox spacing="5">
                                <Label text="Harga:" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Rp 1.200.000" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <Label text="Penghuni: Siti Nurhaliza" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <HBox spacing="5" style="-fx-padding: 5 0;">
                            <Button text="Edit" className="btn-secondary" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                            <Button text="Hapus" className="btn-danger" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                        </HBox>
                    </VBox>

                    <!-- Room Card 4 -->
                    <VBox className="card" spacing="10" GridPane.columnIndex="3" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_RIGHT">
                            <Label text="Tersedia" style="-fx-background-color: #D9E1F1; -fx-text-fill: #31487A; -fx-font-size: 10px; -fx-padding: 3 8; -fx-border-radius: 3;" />
                        </HBox>
                        <VBox spacing="5">
                            <Label text="🛏️ Kamar 104" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                            <Label text="Tipe: Double Bed" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                            <Label text="Lantai 1 • Area B" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <Separator />
                        <VBox spacing="2">
                            <HBox spacing="5">
                                <Label text="Harga:" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                                <Label text="Rp 1.200.000" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <Label text="Penghuni: -" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
                        </VBox>
                        <HBox spacing="5" style="-fx-padding: 5 0;">
                            <Button text="Edit" className="btn-secondary" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                            <Button text="Hapus" className="btn-danger" HBox.hgrow="ALWAYS" style="-fx-padding: 4 8; -fx-font-size: 9px;" />
                        </HBox>
                    </VBox>
                </GridPane>

                <!-- PAGINATION -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Button text="← Sebelumnya" className="btn-outline" prefWidth="100" />
                    <Label text="Halaman 1 dari 3" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                    <Button text="Selanjutnya →" className="btn-outline" prefWidth="100" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
