<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kosku.controller.pemilik.LaporanPembayaranController">
    <top>
        <fx:include fx:id="navbar" source="navbarPemilik.fxml" />
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="main-container">
            <content>
                <VBox spacing="25.0" styleClass="page-content">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="label-title" text="Laporan Pembayaran Penyewa" />
                                <Label styleClass="text-muted" text="Pantau dan kelola semua histori transaksi keuangan dari penyewa Anda" />
                            </children>
                        </VBox>

                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card" style="-fx-padding: 15;">
                            <children>
                                <DatePicker prefWidth="150.0" promptText="Dari Tanggal" styleClass="text-field" />
                                <DatePicker prefWidth="150.0" promptText="Sampai Tanggal" styleClass="text-field" />
                                <ComboBox prefWidth="180.0" promptText="Status" styleClass="combo-box">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua" />
                                            <String fx:value="Lunas" />
                                            <String fx:value="Pending" />
                                            <String fx:value="Tertunda" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <ComboBox prefWidth="180.0" promptText="Pilih Kos" styleClass="combo-box">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua Kos" />
                                            <String fx:value="Kos Kurniawan - Utama" />
                                            <String fx:value="Kos Kurniawan - Cabang 1" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <Button prefWidth="100.0" styleClass="btn-secondary" text="🔍 Filter" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button prefWidth="80.0" styleClass="btn-outline" text="↻ Reset" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="💰 Total Pendapatan" />
                                        <Label styleClass="stat-value" text="Rp 28.5M" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="✅ Transaksi Lunas" />
                                        <Label styleClass="stat-value" text="27" textFill="#10b981" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="stat-label" text="⏳ Transaksi Pending" />
                                        <Label styleClass="stat-value" text="1" textFill="#f59e0b" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="15.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="label-subtitle" text="Detail Histori Pembayaran" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button styleClass="btn-outline" text="📥 Unduh CSV" />
                                                <Button styleClass="btn-primary" text="🖨️ Cetak Laporan" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <TableView prefHeight="350.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="60.0" text="No" />
                                        <TableColumn prefWidth="200.0" text="Penyewa" />
                                        <TableColumn prefWidth="180.0" text="Properti" />
                                        <TableColumn prefWidth="150.0" text="Jumlah" />
                                        <TableColumn prefWidth="150.0" text="Metode" />
                                        <TableColumn prefWidth="150.0" text="Status" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>