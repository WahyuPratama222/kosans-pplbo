<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);">
            <left>
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="💰 Laporan Pembayaran" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button style="-fx-text-fill: white; -fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 5;" text="← Kembali" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                    </padding>
                    <BorderPane.margin>
                        <Insets right="20.0" />
                    </BorderPane.margin>
                </Button>
            </right>
        </BorderPane>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 25;">
                    <children>
                        <VBox spacing="10.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Laporan Pembayaran Penyewa" />
                                                <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px;" text="Pantau dan kelola semua pembayaran dari penyewa Anda" />
                                            </children>
                                        </VBox>
                                        <Button prefWidth="150.0" text="📥 Unduh Laporan" />
                                        <Button prefWidth="100.0" text="🖨️ Cetak" />
                                    </children>
                                </HBox>
                                <Separator />
                            </children>
                        </VBox>

                        <HBox spacing="10.0">
                            <children>
                                <DatePicker prefWidth="150.0" promptText="Dari Tanggal" />
                                <DatePicker prefWidth="150.0" promptText="Sampai Tanggal" />
                                <ComboBox prefWidth="180.0" promptText="Status Pembayaran">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua" />
                                            <String fx:value="Lunas" />
                                            <String fx:value="Pending" />
                                            <String fx:value="Tertunda" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <ComboBox prefWidth="180.0" promptText="Pilih Kos">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua Kos" />
                                            <String fx:value="Kos Kurniawan - Utama" />
                                            <String fx:value="Kos Kurniawan - Cabang 1" />
                                            <String fx:value="Kos Kurniawan - Cabang 2" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <Button prefWidth="100.0" text="🔍 Filter" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button prefWidth="80.0" text="↻ Reset" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Total Pembayaran Bulan Ini" textFill="#64748b" />
                                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Rp 28.5M" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Pembayaran Lunas" textFill="#10b981" />
                                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="27" textFill="#10b981" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Pembayaran Pending" textFill="#f59e0b" />
                                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="1" textFill="#f59e0b" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Detail Pembayaran" />
                                <TableView prefHeight="300.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="40.0" text="No" />
                                        <TableColumn prefWidth="150.0" text="Nama" />
                                        <TableColumn prefWidth="100.0" text="Kamar" />
                                        <TableColumn prefWidth="120.0" text="Jumlah" />
                                        <TableColumn prefWidth="120.0" text="Status" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Ringkasan" />
                                        <HBox spacing="20.0">
                                            <children>
                                                <Label text="Total Transaksi: 28" />
                                                <Label text="Rata-rata: Rp 1.02M" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Metode" />
                                        <Label text="💳 Transfer: 64%" />
                                        <Label text="📱 E-wallet: 29%" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10;">
                            <children>
                                <Button prefWidth="120.0" text="← Sebelumnya" />
                                <Label style="-fx-font-weight: bold;" text="Halaman 1 dari 5" />
                                <Button prefWidth="120.0" text="Selanjutnya →" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>