<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css">
    <!-- TOP NAVBAR -->
    <top>
        <BorderPane prefHeight="60.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to right, #1E2E4F, #31487A);" className="navbar-pemilik">
            <left>
                <Label text="💰 Laporan Pembayaran" style="-fx-text-fill: white;" className="navbar-title" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </left>
            <right>
                <Button text="← Kembali" className="btn-outline" style="-fx-text-fill: white; -fx-padding: 5 15; -fx-border-color: white;" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Button>
            </right>
        </BorderPane>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #F8FAFC;">
            <VBox spacing="20" className="page-content">
                <!-- HEADER -->
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Laporan Pembayaran Penyewa" className="label-title" />
                            <Label text="Pantau dan kelola semua pembayaran dari penyewa Anda" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        </VBox>
                        <Button text="📥 Unduh Laporan" className="btn-secondary" prefWidth="150" />
                        <Button text="🖨️ Cetak" className="btn-outline" prefWidth="100" />
                    </HBox>
                    <Separator />
                </VBox>

                <!-- FILTER -->
                <HBox spacing="10">
                    <DatePicker promptText="Dari Tanggal" className="text-field" prefWidth="150" />
                    <DatePicker promptText="Sampai Tanggal" className="text-field" prefWidth="150" />
                    <ComboBox promptText="Status Pembayaran" prefWidth="180" className="combo-box">
                        <items>
                            <String fx:value="Semua" />
                            <String fx:value="Lunas" />
                            <String fx:value="Pending" />
                            <String fx:value="Tertunda" />
                        </items>
                    </ComboBox>
                    <ComboBox promptText="Pilih Kos" prefWidth="180" className="combo-box">
                        <items>
                            <String fx:value="Semua Kos" />
                            <String fx:value="Kos Kurniawan - Utama" />
                            <String fx:value="Kos Kurniawan - Cabang 1" />
                            <String fx:value="Kos Kurniawan - Cabang 2" />
                        </items>
                    </ComboBox>
                    <Button text="🔍 Filter" className="btn-secondary" prefWidth="100" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻ Reset" className="btn-outline" prefWidth="80" />
                </HBox>

                <!-- STATISTICS SECTION -->
                <HBox spacing="15">
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Total Pembayaran Bulan Ini" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="Rp 28.5M" style="-fx-text-fill: #1E2E4F; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Pembayaran Lunas" style="-fx-text-fill: #10B981; -fx-font-size: 12px;" />
                        <Label text="27" style="-fx-text-fill: #10B981; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Pembayaran Pending" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;" />
                        <Label text="1" style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox className="stat-card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-padding: 12;">
                        <Label text="Pembayaran Tertunda" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;" />
                        <Label text="0" style="-fx-text-fill: #EF4444; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- PAYMENT CHART PLACEHOLDER -->
                <VBox className="card" spacing="10">
                    <Label text="Grafik Pembayaran (Placeholder)" className="card-header" />
                    <VBox style="-fx-background-color: #F8FAFC; -fx-alignment: center; -fx-padding: 40;" VBox.vgrow="ALWAYS">
                        <Label text="📊 Grafik akan ditampilkan di sini" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                        <Label text="(Menggunakan library chart seperti XChart)" style="-fx-text-fill: #64748B; -fx-font-size: 10px;" />
                    </VBox>
                </VBox>

                <!-- PAYMENT TABLE -->
                <VBox className="card" spacing="10">
                    <Label text="Detail Pembayaran" className="card-header" />
                    <TableView style="-fx-font-size: 11px;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="No" prefWidth="40" />
                            <TableColumn text="Nama Penyewa" prefWidth="140" />
                            <TableColumn text="Kamar" prefWidth="80" />
                            <TableColumn text="Periode Bayar" prefWidth="130" />
                            <TableColumn text="Jumlah" prefWidth="120" />
                            <TableColumn text="Tanggal Bayar" prefWidth="120" />
                            <TableColumn text="Status" prefWidth="100" />
                            <TableColumn text="Metode" prefWidth="100" />
                            <TableColumn text="Aksi" prefWidth="120" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- SUMMARY SECTION -->
                <HBox spacing="15">
                    <!-- Left: Ringkasan -->
                    <VBox className="card" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Ringkasan Pembayaran" className="card-header" />
                        <HBox spacing="20" style="-fx-padding: 10 0;">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Total Transaksi" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" />
                                <Label text="28" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Total Jumlah" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" />
                                <Label text="Rp 28.5M" style="-fx-text-fill: #10B981; -fx-font-weight: bold;" />
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Rata-rata" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" />
                                <Label text="Rp 1.02M" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Right: Metode Pembayaran -->
                    <VBox className="card" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="Metode Pembayaran" className="card-header" />
                        <VBox spacing="6" style="-fx-padding: 5;">
                            <HBox spacing="10">
                                <Label text="💳 Transfer Bank:" style="-fx-font-size: 11px;" />
                                <Label text="18 transaksi" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                                <Label text="64%" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="📱 E-wallet:" style="-fx-font-size: 11px;" />
                                <Label text="8 transaksi" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                                <Label text="29%" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                            <HBox spacing="10">
                                <Label text="💵 Tunai:" style="-fx-font-size: 11px;" />
                                <Label text="2 transaksi" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                                <Label text="7%" style="-fx-font-weight: bold; -fx-font-size: 11px;" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- PAGINATION -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Button text="← Sebelumnya" className="btn-outline" prefWidth="100" />
                    <Label text="Halaman 1 dari 5" style="-fx-text-fill: #1E2E4F; -fx-font-weight: bold;" />
                    <Button text="Selanjutnya →" className="btn-outline" prefWidth="100" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
